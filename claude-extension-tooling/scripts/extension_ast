#!/usr/bin/env bash
#
# extension_ast — explore and rewrite extension code using ast-grep.
#
# Operates on an unpacked extension directory (e.g. from extension_transformer).
# No sourcemaps needed — ast-grep matches structural patterns in the AST,
# so it works on minified/bundled code just fine.
#
# INSTALL
# -------
#   brew install ast-grep        # provides the `sg` binary
#
# QUICK START
# -----------
#   # Point at your latest extension copy:
#   EXT=~/ClaudeChromeExtension/latest
#
#   # Search for a pattern across all JS:
#   ./extension_ast search "$EXT" 'this.cache.get($KEY)'
#
#   # Preview what a rewrite would look like (colored diff):
#   ./extension_ast search "$EXT" 'this.CACHE_TTL_MS' -r '0'
#
#   # Save a rule to config, apply later:
#   ./extension_ast init                     # create rules dir with examples
#   vim ~/.config/extension_transformer/rules/my-rule.yml
#   ./extension_ast preview "$EXT"           # dry-run all rules
#   ./extension_ast apply "$EXT"             # apply all rules
#
# RULES
# -----
#   Rules live in ~/.config/extension_transformer/rules/ as YAML files
#   using ast-grep's native rule format:
#
#     id: bypass-cache-ttl
#     language: JavaScript
#     rule:
#       pattern: this.CACHE_TTL_MS
#     fix: '0'
#
#   This means you get ast-grep's full power — nested rules, constraints,
#   regex matching, etc. See: https://ast-grep.github.io/guide/rule-config.html
#
# HOOKING INTO extension_transformer
# -----------------------------------
#   In your hooks file (~/.config/extension_transformer/hooks.sh):
#
#     apply_local_transforms() {
#       local destination="$1"
#       ~/extension_ast apply "$destination"
#     }
#
#   Now every extension_transformer run automatically applies your ast rules.
#

set -Eeuo pipefail

PROGRAM_NAME="${0##*/}"
DEFAULT_RULES_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/extension_transformer/rules"
RULES_DIR="${RULES_DIR:-$DEFAULT_RULES_DIR}"
SG="${SG:-sg}"

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------

if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  C_RESET=$'\033[0m'
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_CYAN=$'\033[36m'
  C_DIM=$'\033[2m'
  C_BOLD=$'\033[1m'
else
  C_RESET="" C_RED="" C_GREEN="" C_YELLOW="" C_CYAN="" C_DIM="" C_BOLD=""
fi

info()    { printf '%s%s%s\n' "$C_CYAN" "$*" "$C_RESET"; }
success() { printf '%s%s%s\n' "$C_GREEN" "$*" "$C_RESET"; }
warn()    { printf '%sWarning:%s %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2; }
die()     { printf '%sError:%s %s\n' "$C_RED" "$C_RESET" "$*" >&2; exit 1; }
dim()     { printf '%s%s%s\n' "$C_DIM" "$*" "$C_RESET"; }
bold()    { printf '%s%s%s\n' "$C_BOLD" "$*" "$C_RESET"; }

# ---------------------------------------------------------------------------
# Prereqs
# ---------------------------------------------------------------------------

require_sg() {
  command -v "$SG" >/dev/null 2>&1 || die \
    "ast-grep not found. Install it:
    brew install ast-grep
  Or set SG=/path/to/sg"
}

require_dir() {
  local dir="$1"
  [[ -d "$dir" ]] || die "Directory not found: $dir"
}

# Find all JS/TS files in an extension directory.
find_js_files() {
  local dir="$1"
  find "$dir" -type f \( -name '*.js' -o -name '*.mjs' -o -name '*.ts' -o -name '*.jsx' -o -name '*.tsx' \) \
    ! -path '*/.git/*' ! -path '*/node_modules/*'
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

# search <dir> <pattern> [-r|--rewrite <replacement>] [-l|--lang <lang>] [-c|--context <chars>]
#
# Find all matches for a structural pattern. Shows the matched text with
# a character-level context window — essential for reading minified code.
# If --rewrite is given, shows the replacement inline.
cmd_search() {
  local dir="" pattern="" rewrite="" lang="js" context=60

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -r|--rewrite)   [[ $# -ge 2 ]] || die "--rewrite needs a value"; rewrite="$2"; shift 2 ;;
      -l|--lang)      [[ $# -ge 2 ]] || die "--lang needs a value"; lang="$2"; shift 2 ;;
      -c|--context)   [[ $# -ge 2 ]] || die "--context needs a value"; context="$2"; shift 2 ;;
      -*)             die "Unknown flag: $1" ;;
      *)
        if [[ -z "$dir" ]]; then dir="$1"
        elif [[ -z "$pattern" ]]; then pattern="$1"
        else die "Unexpected argument: $1"
        fi
        shift ;;
    esac
  done

  [[ -n "$dir" ]] || die "Usage: $PROGRAM_NAME search <dir> '<pattern>' [-r '<rewrite>']"
  [[ -n "$pattern" ]] || die "Usage: $PROGRAM_NAME search <dir> '<pattern>' [-r '<rewrite>']"
  require_dir "$dir"
  require_sg

  local sg_args=( run --pattern "$pattern" --lang "$lang" --json )

  if [[ -n "$rewrite" ]]; then
    sg_args+=( --rewrite "$rewrite" )
  fi

  sg_args+=( "$dir" )

  # Pipe ast-grep JSON through a python3 formatter that extracts
  # character-level context windows — essential for minified code
  # where line-level context dumps the entire 200KB file.
  ( "$SG" "${sg_args[@]}" 2>/dev/null || true ) | python3 -c '
import json, sys, os
from collections import OrderedDict

context_chars = int(sys.argv[1])
base_dir = sys.argv[2]

raw_input = sys.stdin.read().strip()
if not raw_input:
    print("No matches found.")
    sys.exit(0)

matches = json.loads(raw_input)
if not matches:
    print("No matches found.")
    sys.exit(0)

CYAN    = "\033[36m"
GREEN   = "\033[32m"
RED     = "\033[31m"
YELLOW  = "\033[1;33m"
DIM     = "\033[2m"
BOLD    = "\033[1m"
RESET   = "\033[0m"

if os.environ.get("NO_COLOR") or not sys.stdout.isatty():
    CYAN = GREEN = RED = YELLOW = DIM = BOLD = RESET = ""

file_cache = {}
def read_file(path):
    if path not in file_cache:
        try:
            with open(path, "rb") as f:
                file_cache[path] = f.read()
        except OSError:
            file_cache[path] = b""
    return file_cache[path]

by_file = OrderedDict()
for m in matches:
    by_file.setdefault(m["file"], []).append(m)

total = len(matches)
file_count = len(by_file)

for filepath, file_matches in by_file.items():
    rel = os.path.relpath(filepath, base_dir)
    print(f"{CYAN}{rel}{RESET}")

    raw = read_file(filepath)

    for m in file_matches:
        byte_start = m["range"]["byteOffset"]["start"]
        byte_end = m["range"]["byteOffset"]["end"]
        line = m["range"]["start"]["line"] + 1
        col = m["range"]["start"]["column"] + 1
        matched_text = m["text"]
        replacement = m.get("replacement")

        ctx_start = max(0, byte_start - context_chars)
        ctx_end = min(len(raw), byte_end + context_chars)

        before = raw[ctx_start:byte_start].decode("utf-8", errors="replace").replace("\n", "↵")
        after = raw[byte_end:ctx_end].decode("utf-8", errors="replace").replace("\n", "↵")

        el = "…" if ctx_start > 0 else ""
        er = "…" if ctx_end < len(raw) else ""

        print(f"  {DIM}:{line}:{col}{RESET}")

        if replacement is not None:
            print(f"    {DIM}{el}{before}{RESET}{RED}{matched_text}{RESET}{DIM}{after}{er}{RESET}")
            print(f"    {DIM}{el}{before}{RESET}{GREEN}{replacement}{RESET}{DIM}{after}{er}{RESET}")
        else:
            print(f"    {DIM}{el}{before}{RESET}{YELLOW}{matched_text}{RESET}{DIM}{after}{er}{RESET}")

        print()

print(f"{DIM}{chr(9472) * 40}{RESET}")
ms = "es" if total != 1 else ""
fs = "s" if file_count != 1 else ""
print(f"{BOLD}{total} match{ms}{RESET} in {file_count} file{fs}")
' "$context" "$dir"
}

# preview <dir> [--rules <dir>] [--rule <file>]
#
# Show what all configured rules would change, without modifying files.
cmd_preview() {
  local dir="" rules_path=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --rules) [[ $# -ge 2 ]] || die "--rules needs a value"; rules_path="$2"; shift 2 ;;
      --rule)  [[ $# -ge 2 ]] || die "--rule needs a value"; rules_path="$2"; shift 2 ;;
      -*)      die "Unknown flag: $1" ;;
      *)       [[ -z "$dir" ]] && dir="$1" || die "Unexpected: $1"; shift ;;
    esac
  done

  [[ -n "$dir" ]] || die "Usage: $PROGRAM_NAME preview <dir> [--rules <dir>]"
  require_dir "$dir"
  require_sg

  rules_path="${rules_path:-$RULES_DIR}"
  [[ -d "$rules_path" || -f "$rules_path" ]] || die "Rules not found: $rules_path (run '$PROGRAM_NAME init' to create)"

  local rule_count
  if [[ -d "$rules_path" ]]; then
    rule_count="$(find "$rules_path" -name '*.yml' -o -name '*.yaml' | wc -l | tr -d ' ')"
    [[ "$rule_count" -gt 0 ]] || die "No .yml rule files found in: $rules_path"
    info "Previewing $rule_count rule(s) from: $rules_path"
  else
    rule_count=1
    info "Previewing rule: $rules_path"
  fi
  echo

  # Run each rule file individually for clearer output.
  local rule_file matched=0
  while IFS= read -r rule_file; do
    local rule_id
    rule_id="$(sed -n 's/^id:[[:space:]]*//p' "$rule_file" | head -1)"
    rule_id="${rule_id:-$(basename "$rule_file" .yml)}"

    bold "Rule: $rule_id"
    dim "File: $rule_file"

    if "$SG" scan --rule "$rule_file" "$dir" 2>/dev/null; then
      matched=1
    else
      dim "  (no matches)"
    fi
    echo
  done < <(
    if [[ -d "$rules_path" ]]; then
      find "$rules_path" -name '*.yml' -o -name '*.yaml' | LC_ALL=C sort
    else
      printf '%s\n' "$rules_path"
    fi
  )

  if [[ "$matched" -eq 0 ]]; then
    info "No matches across any rules."
  else
    warn "These are previews only. Run '$PROGRAM_NAME apply $dir' to apply."
  fi
}

# apply <dir> [--rules <dir>] [--rule <file>]
#
# Apply all rules, modifying files in place.
cmd_apply() {
  local dir="" rules_path=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --rules) [[ $# -ge 2 ]] || die "--rules needs a value"; rules_path="$2"; shift 2 ;;
      --rule)  [[ $# -ge 2 ]] || die "--rule needs a value"; rules_path="$2"; shift 2 ;;
      -*)      die "Unknown flag: $1" ;;
      *)       [[ -z "$dir" ]] && dir="$1" || die "Unexpected: $1"; shift ;;
    esac
  done

  [[ -n "$dir" ]] || die "Usage: $PROGRAM_NAME apply <dir> [--rules <dir>]"
  require_dir "$dir"
  require_sg

  rules_path="${rules_path:-$RULES_DIR}"
  [[ -d "$rules_path" || -f "$rules_path" ]] || die "Rules not found: $rules_path (run '$PROGRAM_NAME init' to create)"

  local rule_file applied=0
  while IFS= read -r rule_file; do
    local rule_id
    rule_id="$(sed -n 's/^id:[[:space:]]*//p' "$rule_file" | head -1)"
    rule_id="${rule_id:-$(basename "$rule_file" .yml)}"

    info "Applying: $rule_id"

    if "$SG" scan --rule "$rule_file" --update-all "$dir" 2>/dev/null; then
      applied=1
      success "  applied"
    else
      dim "  (no matches)"
    fi
  done < <(
    if [[ -d "$rules_path" ]]; then
      find "$rules_path" -name '*.yml' -o -name '*.yaml' | LC_ALL=C sort
    else
      printf '%s\n' "$rules_path"
    fi
  )

  echo
  if [[ "$applied" -eq 1 ]]; then
    success "Transforms applied to: $dir"
  else
    info "No rules matched — nothing changed."
  fi
}

# init — create the rules directory with example rules.
cmd_init() {
  if [[ -d "$RULES_DIR" ]]; then
    local existing
    existing="$(find "$RULES_DIR" -name '*.yml' -o -name '*.yaml' | wc -l | tr -d ' ')"
    info "Rules directory already exists: $RULES_DIR ($existing rule(s))"
    echo
  else
    mkdir -p "$RULES_DIR"
    success "Created: $RULES_DIR"
  fi

  # Write example rules if they don't exist yet.
  if [[ ! -f "$RULES_DIR/example-bypass-cache-ttl.yml" ]]; then
    cat > "$RULES_DIR/example-bypass-cache-ttl.yml" <<'YAML'
# Example: zero out a cache TTL check so the cache is always stale.
# Matches:  Date.now() - $CACHE.timestamp > this.CACHE_TTL_MS
# Replaces: true  (always re-fetch)

id: bypass-cache-ttl
language: JavaScript
rule:
  pattern: Date.now() - $CACHE.timestamp > this.CACHE_TTL_MS
fix: 'true'
YAML
    success "  wrote example: example-bypass-cache-ttl.yml"
  fi

  if [[ ! -f "$RULES_DIR/example-log-api-calls.yml" ]]; then
    cat > "$RULES_DIR/example-log-api-calls.yml" <<'YAML'
# Example: wrap fetchCategoryFromAPI calls with a console.log.

id: log-api-calls
language: JavaScript
rule:
  pattern: this.fetchCategoryFromAPI($KEY)
fix: |-
  (console.log('[ext-ast] fetchCategoryFromAPI', $KEY), this.fetchCategoryFromAPI($KEY))
YAML
    success "  wrote example: example-log-api-calls.yml"
  fi

  if [[ ! -f "$RULES_DIR/example-match-cache-class.yml" ]]; then
    cat > "$RULES_DIR/example-match-cache-class.yml" <<'YAML'
# Example: search-only rule (no fix). Finds classes that use the
# cache + pendingRequests pattern. Useful for exploration.
#
# Run with:  extension_ast search <dir> 'this.pendingRequests.get($KEY)'
# Or use this rule with:  extension_ast preview <dir>

id: find-cache-pattern
language: JavaScript
severity: hint
rule:
  pattern: this.pendingRequests.get($KEY)
message: 'Found pending-request cache pattern using key: $KEY'
YAML
    success "  wrote example: example-match-cache-class.yml"
  fi

  echo
  info "Rules directory: $RULES_DIR"
  echo
  cat <<EOF
Workflow:
  1. Search for patterns interactively:
     ${C_DIM}$PROGRAM_NAME search <ext-dir> 'this.cache.get(\$KEY)'${C_RESET}

  2. Preview what a rewrite looks like:
     ${C_DIM}$PROGRAM_NAME search <ext-dir> 'this.CACHE_TTL_MS' -r '0'${C_RESET}

  3. When happy, save it as a rule:
     ${C_DIM}vim $RULES_DIR/my-rule.yml${C_RESET}

  4. Preview all rules against an extension:
     ${C_DIM}$PROGRAM_NAME preview <ext-dir>${C_RESET}

  5. Apply:
     ${C_DIM}$PROGRAM_NAME apply <ext-dir>${C_RESET}

  6. Wire into extension_transformer hooks:
     ${C_DIM}# In ~/.config/extension_transformer/hooks.sh:${C_RESET}
     ${C_DIM}apply_local_transforms() { ~/extension_ast apply "\$1"; }${C_RESET}
EOF
}

# ls <dir> — list JS/TS files in the extension, with line counts.
cmd_ls() {
  local dir="$1"
  [[ -n "$dir" ]] || die "Usage: $PROGRAM_NAME ls <dir>"
  require_dir "$dir"

  local total_files=0 total_lines=0

  while IFS= read -r file; do
    local lines rel
    lines="$(wc -l < "$file" | tr -d ' ')"
    rel="${file#"$dir"/}"
    printf '%s%6s%s  %s\n' "$C_DIM" "$lines" "$C_RESET" "$rel"
    total_files=$((total_files + 1))
    total_lines=$((total_lines + lines))
  done < <(find_js_files "$dir" | LC_ALL=C sort)

  echo
  info "$total_files files, $total_lines lines"
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
  cat <<EOF
Usage: $PROGRAM_NAME <command> [args]

Commands:
  search <dir> '<pattern>' [-r '<rewrite>'] [-l <lang>]
      Find structural pattern matches across all JS/TS files.
      With -r, shows a colored diff preview of the rewrite.

  preview <dir> [--rules <dir>] [--rule <file>]
      Dry-run all configured rules. Shows matches without changing files.

  apply <dir> [--rules <dir>] [--rule <file>]
      Apply all configured rules, modifying files in place.

  ls <dir>
      List JS/TS files in the extension with line counts.

  init
      Create the rules directory with example rule files.

  help
      Show this help.

Rules directory: $RULES_DIR
  Override with: RULES_DIR=/path/to/rules

Examples:
  $PROGRAM_NAME search ./ext 'this.cache.get(\$KEY)'
  $PROGRAM_NAME search ./ext 'this.CACHE_TTL_MS' -r '0'
  $PROGRAM_NAME preview ./ext
  $PROGRAM_NAME apply ./ext
  $PROGRAM_NAME apply ./ext --rule ./my-rule.yml
EOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    search)   cmd_search "$@" ;;
    preview)  cmd_preview "$@" ;;
    apply)    cmd_apply "$@" ;;
    ls)       cmd_ls "$@" ;;
    init)     cmd_init ;;
    help|-h|--help) usage ;;
    *)        die "Unknown command: $cmd (try '$PROGRAM_NAME help')" ;;
  esac
}

main "$@"
